DELIMITER //
CREATE FUNCTION TotalSteps(
uid INT,
startDate DATE,
endDate DATE
)
RETURNS INT
DETERMINISTIC
BEGIN
DECLARE total INT;

SELECT SUM(step_count)
INTO total
FROM Steps
WHERE user_ID=uid
AND tracking_date BETWEEN startDate AND endDate;

RETURN total;
END //
DELIMITER ;

