5) Cursor to display user names one by one
DELIMITER //

CREATE PROCEDURE DisplayUsers()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE uname VARCHAR(50);

    DECLARE cur CURSOR FOR
    SELECT name FROM Users;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;

    OPEN cur;

    read_loop: LOOP
        FETCH cur INTO uname;

        IF done=1 THEN
            LEAVE read_loop;
        END IF;

        SELECT uname;
    END LOOP;

    CLOSE cur;
END //

DELIMITER ;
Execute Procedure
CALL DisplayUsers();
6) Procedure to insert new workout
DELIMITER //

CREATE PROCEDURE InsertWorkout(
IN wid INT,
IN uid INT,
IN wdate DATE,
IN wtype VARCHAR(50),
IN st TIME,
IN et TIME,
IN duration INT
)
BEGIN
    INSERT INTO Workouts
    VALUES(wid,uid,wdate,wtype,st,et,duration);
END //

DELIMITER ;
