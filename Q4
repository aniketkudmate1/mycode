1) Function to check out of stock product
DELIMITER //

CREATE FUNCTION CheckStock(pid INT)
RETURNS VARCHAR(20)
DETERMINISTIC
BEGIN
    DECLARE total INT;

    SELECT SUM(quantity_in_stock)
    INTO total
    FROM Inventory
    WHERE product_ID=pid;

    IF total=0 THEN
        RETURN 'Out of Stock';
    ELSE
        RETURN 'Available';
    END IF;
END //

DELIMITER ;
Execute
SELECT CheckStock(102);
