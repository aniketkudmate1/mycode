4) Cursor to display products and stock
DELIMITER //

CREATE PROCEDURE ProductStock()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE pname VARCHAR(50);
    DECLARE stock INT;

    DECLARE cur CURSOR FOR
    SELECT P.name,SUM(I.quantity_in_stock)
    FROM Products P
    JOIN Inventory I
    ON P.product_ID=I.product_ID
    GROUP BY P.name;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;

    OPEN cur;

    read_loop: LOOP

    FETCH cur INTO pname,stock;

    IF done=1 THEN
        LEAVE read_loop;
    END IF;

    SELECT pname,stock;

    END LOOP;

    CLOSE cur;
END //

DELIMITER ;
Execute
CALL ProductStock();
