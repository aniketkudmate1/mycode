4) View for low stock products
CREATE VIEW LowStockProducts AS
SELECT P.name,
SUM(I.quantity_in_stock) AS total_stock
FROM Products P
JOIN Inventory I
ON P.product_ID=I.product_ID
GROUP BY P.name
HAVING total_stock < 10;
Display View
