6) Trigger to prevent negative stock
DELIMITER //

CREATE TRIGGER check_stock
BEFORE INSERT ON Inventory
FOR EACH ROW
BEGIN
    IF NEW.quantity_in_stock < 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT='Stock cannot be negative';
    END IF;
END //

DELIMITER ;
