3) Trigger to backup deleted products
CREATE TABLE ProductBackup(
    product_ID INT,
    name VARCHAR(50),
    description VARCHAR(100),
    price INT,
    category_ID INT
);
DELIMITER //

CREATE TRIGGER backup_product
BEFORE DELETE ON Products
FOR EACH ROW
BEGIN
    INSERT INTO ProductBackup
    VALUES(
        OLD.product_ID,
        OLD.name,
        OLD.description,
        OLD.price,
        OLD.category_ID
    );
END //

DELIMITER ;
