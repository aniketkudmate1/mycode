2) Highest and lowest priced items
SELECT item_name,price
FROM Menu
WHERE price=
(SELECT MAX(price) FROM Menu)
OR price=
(SELECT MIN(price) FROM Menu);
3) Count items in each category
SELECT category,
COUNT(*) AS total_items
FROM Menu
GROUP BY category;
4) Average items per order
SELECT AVG(quantity) AS average_items
FROM OrderItems;
5) Item names in specific order
SELECT M.item_name
FROM Menu M
JOIN OrderItems OI
ON M.item_ID=OI.item_ID
WHERE OI.order_ID=1;
6) Customers with more than 3 orders
SELECT customer_ID,
COUNT(order_ID) AS total_orders
FROM Orders
GROUP BY customer_ID
HAVING COUNT(order_ID) > 3;
7) Items with average unit price greater than 200
SELECT item_ID,
AVG(unit_price) AS average_price
FROM OrderItems
GROUP BY item_ID
HAVING AVG(unit_price) > 200;

