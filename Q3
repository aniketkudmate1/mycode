3) Trigger to log deleted customers
CREATE TABLE CustomerBackup(
    customer_ID INT,
    name VARCHAR(50),
    contact_number VARCHAR(15)
);
DELIMITER //

CREATE TRIGGER backup_customer
BEFORE DELETE ON Customers
FOR EACH ROW
BEGIN
    INSERT INTO CustomerBackup
    VALUES(
        OLD.customer_ID,
        OLD.name,
        OLD.contact_number
    );
END //

DELIMITER ;
