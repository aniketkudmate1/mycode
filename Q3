6) Customers with order amount greater than 1000
SELECT C.name,
SUM(OI.quantity * OI.unit_price) AS total_amount
FROM Customers C
JOIN Orders O
ON C.customer_ID=O.customer_ID
JOIN OrderItems OI
ON O.order_ID=OI.order_ID
GROUP BY C.name
HAVING total_amount > 1000;
