6) Function to check item category
DELIMITER //

CREATE FUNCTION CheckCategory(
iid INT,
cat VARCHAR(50)
)
RETURNS VARCHAR(20)
DETERMINISTIC
BEGIN
    DECLARE result VARCHAR(20);

    IF EXISTS(
        SELECT *
        FROM Menu
        WHERE item_ID=iid
        AND category=cat
    )
    THEN
        SET result='YES';
    ELSE
        SET result='NO';
    END IF;

    RETURN result;
END //

DELIMITER ;
Execute
SELECT CheckCategory(1,'Pizza');
7) Trigger to prevent negative price
DELIMITER //

CREATE TRIGGER check_price
BEFORE INSERT ON Menu
FOR EACH ROW
BEGIN
    IF NEW.price < 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT='Price cannot be negative';
    END IF;
END //

DELIMITER ;

1) Procedure to insert menu item
DELIMITER //

