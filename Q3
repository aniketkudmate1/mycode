FROM Orders
WHERE DATE(order_date_time)=CURDATE();
7) Cursor for daily sales summary
DELIMITER //

CREATE PROCEDURE DailySales()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE total INT;

    DECLARE cur CURSOR FOR
    SELECT SUM(quantity*unit_price)
    FROM OrderItems;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;

    OPEN cur;

    read_loop: LOOP

    FETCH cur INTO total;

    IF done=1 THEN
        LEAVE read_loop;
    END IF;

    SELECT total AS Daily_Sales;

    END LOOP;

    CLOSE cur;
END //

DELIMITER ;

