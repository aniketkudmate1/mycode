2) Stored procedure for specific order details
DELIMITER //

CREATE PROCEDURE GetOrderDetails(IN oid INT)
BEGIN
    SELECT *
    FROM OrderItems
    WHERE order_ID=oid;
END //

DELIMITER ;
Execute
CALL GetOrderDetails(1);
