1) FUNCTION TO CALCULATE ABSENT DAYS
CREATE FUNCTION GetAbsentDays
(
    @StudentID INT,
    @Month INT,
    @Year INT
)
RETURNS INT
AS
BEGIN
    DECLARE @AbsentDays INT;

    SELECT @AbsentDays = COUNT(*)
    FROM Attendance
    WHERE student_ID = @StudentID
    AND status = 'Absent'
    AND MONTH(attendance_date) = @Month
    AND YEAR(attendance_date) = @Year;

    RETURN @AbsentDays;
END;
2) STUDENTS IN 'SE' CLASS HAVING MARKS MORE THAN 20
SELECT DISTINCT s.name
FROM Students s
JOIN Classes c
ON s.class_ID = c.class_ID
JOIN Marks m
ON s.student_ID = m.student_ID
WHERE c.class_name = 'SE'
AND m.marks > 20;
3) STUDENTS WHOSE SECOND LETTER IS 'a'
SELECT name
FROM Students
WHERE name LIKE '_a%';
4) AVERAGE ATTENDANCE PERCENTAGE OF 'SE' CLASS FOR MARCH
SELECT AVG(attendance_percentage) AS AverageAttendance
FROM Attendance
WHERE MONTH(attendance_date) = 3
AND class_ID = (
    SELECT class_ID
    FROM Classes
    WHERE class_name = 'SE'
);
5) STUDENTS WHO SCORED BELOW 10
SELECT DISTINCT s.name
FROM Students s
JOIN Marks m
ON s.student_ID = m.student_ID
WHERE m.marks < 10;
6) TOTAL MARKS OF 'SE' CLASS STUDENTS IN MIDTERM
SELECT 
s.name,
SUM(m.marks) AS TotalMarks
FROM Students s
JOIN Classes c
ON s.class_ID = c.class_ID
JOIN Marks m
ON s.student_ID = m.student_ID
WHERE c.class_name = 'SE'
AND m.exam_name = 'Midterm'
GROUP BY s.name;
7) CURSOR TO DISPLAY STUDENT NAMES
DECLARE @StudentName VARCHAR(50);

DECLARE StudentCursor CURSOR FOR
SELECT name FROM Students;

OPEN StudentCursor;

FETCH NEXT FROM StudentCursor INTO @StudentName;

WHILE @@FETCH_STATUS = 0
BEGIN
    PRINT @StudentName;

    FETCH NEXT FROM StudentCursor INTO @StudentName;
END;

CLOSE StudentCursor;
DEALLOCATE StudentCursor;
1) CREATE VIEW FOR ATTENDANCE SUMMARY
CREATE VIEW AttendanceSummary AS
SELECT 
student_ID,
COUNT(*) AS TotalDays,
SUM(CASE WHEN status='Present' THEN 1 ELSE 0 END) AS PresentDays,
SUM(CASE WHEN status='Absent' THEN 1 ELSE 0 END) AS AbsentDays
FROM Attendance
GROUP BY student_ID;
2) NUMBER OF STUDENTS IN EACH CLASS
SELECT 
c.class_name,
COUNT(s.student_ID) AS TotalStudents
FROM Classes c
LEFT JOIN Students s
ON c.class_ID = s.class_ID
GROUP BY c.class_name;
3) STUDENTS WHOSE NAME STARTS WITH 'D'
SELECT student_ID, name
FROM Students
WHERE name LIKE 'D%';
4) TOTAL NUMBER OF SUBJECTS
SELECT COUNT(*) AS TotalSubjects
FROM Subjects;
5) TRIGGER FOR STUDENT CLASS HISTORY
CREATE TABLE Student_Class_History (
    student_ID INT,
    student_name VARCHAR(50),
    old_class_id INT,
    new_class_id INT,
    changed_on DATETIME
);
TRIGGER
CREATE TRIGGER trg_ClassChange
ON Students
AFTER UPDATE
AS
BEGIN
    INSERT INTO Student_Class_History
    (
        student_ID,
        student_name,
        old_class_id,
        new_class_id,
        changed_on
    )
    SELECT 
        i.student_ID,
        i.name,
        d.class_ID,
        i.class_ID,
        GETDATE()
    FROM inserted i
    JOIN deleted d
    ON i.student_ID = d.student_ID
    WHERE i.class_ID <> d.class_ID;
END;
