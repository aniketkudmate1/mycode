s.name,
c.class_name
FROM Students s
JOIN Classes c
ON s.class_ID = c.class_ID;
2) HIGHEST MARKS IN EACH SUBJECT
SELECT 
subject_ID,
MAX(marks) AS HighestMarks
FROM Marks
GROUP BY subject_ID;
3) TRIGGER TO PREVENT NEGATIVE MARKS
CREATE TRIGGER trg_NoNegativeMarks
ON Marks
INSTEAD OF INSERT
AS
BEGIN
    IF EXISTS (
        SELECT *
        FROM inserted
        WHERE marks < 0
    )
    BEGIN
        PRINT 'Negative marks are not allowed';
    END
    ELSE
    BEGIN
        INSERT INTO Marks
        SELECT * FROM inserted;
    END
END;
4) PROCEDURE TO FIND TOTAL STUDENTS IN CLASS
CREATE PROCEDURE TotalStudentsInClass
@ClassID INT
AS
BEGIN
    SELECT COUNT(*) AS TotalStudents
    FROM Students
    WHERE class_ID = @ClassID;
END;
5) STUDENTS WHOSE TOTAL MARKS > 80
SELECT 
s.name,
SUM(m.marks) AS TotalMarks
FROM Students s
JOIN Marks m
ON s.student_ID = m.student_ID
GROUP BY s.name
HAVING SUM(m.marks) > 80;
6) STUDENTS WHOSE NAME CONTAINS 'sh'
SELECT *
FROM Students
WHERE name LIKE '%sh%';
7) SUBJECTS WHOSE AVERAGE MARKS ARE ABOVE OVERALL AVERAGE
SELECT 
subject_ID,
AVG(marks) AS SubjectAverage
FROM Marks
GROUP BY subject_ID
HAVING AVG(marks) >
(
    SELECT AVG(marks)
    FROM Marks
);
